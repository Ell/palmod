{
  "version": 6,
  "configurePresets": [
    {
      "name": "dev",
      "displayName": "Palmod native development build",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/../build/native",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "PALMOD_BUILD_TESTS": "ON"
      }
    }
  ],
  "buildPresets": [
    { "name": "dev", "configurePreset": "dev" }
  ],
  "testPresets": [
    {
      "name": "dev",
      "configurePreset": "dev",
      "output": { "outputOnFailure": true }
    }
  ]
}
